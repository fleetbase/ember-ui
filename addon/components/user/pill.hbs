<Pill
    @resource={{this.resource}}
    @imageSrc={{avatar-url this.resource.avatar_url}}
    @titleFallback={{or @titleFallback "No user"}}
    @subtitle={{n-a this.resource.email (if this.resource "No email" "-")}}
    @fallbackImageType="userImage"
    @noTooltip={{not this.resource}}
    @onClick={{@onClick}}
    @anchorClass={{@anchorClass}}
    @imageClass={{@imageClass}}
    @imageWrapperClass={{@imageWrapperClass}}
    @contentWrapperClass={{@contentWrapperClass}}
    @titleClass={{@titleClass}}
    @subtitleClass={{@subtitleClass}}
    ...attributes
/>
